{
  "name": "cia-alpha44",
  "version": "0.1.0",
  "private": true,
  "description": "CIA / Alpha 44 — Sistema de Cotação de Importação (SaaS)",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "build:api": "npm run build -w @cia/shared -w @cia/fiscal-engine -w @cia/pipeline -w @cia/db -w @cia/api",
    "build:web": "npm run build -w @cia/web",
    "start:api": "npm run start -w @cia/api",
    "engine:test": "npm run test -w @cia/fiscal-engine",
    "db:generate": "npm run db:generate -w @cia/db",
    "db:migrate:deploy": "npm run db:migrate:deploy -w @cia/db",
    "db:seed": "npm run db:seed -w @cia/db",
    "seed:comexstat": "npm run build -w @cia/pipeline && node tools/fetch-comexstat-api.cjs"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "xlsx": "^0.18.5"
  }
}
