# =============================================================================
# CIA / Alpha 44 — variáveis de ambiente
# Copie para .env (local) ou configure nos painéis Render / Vercel (produção).
# =============================================================================

# ---- API (local ou Render) ----
PORT=3333
HOST=0.0.0.0
NODE_ENV=development

# CORS: origens permitidas (vírgula). Produção VPS: Vercel + localhost dev.
# Exemplo produção: https://cia-alpha44-web.vercel.app,http://localhost:5173
WEB_ORIGIN=http://localhost:5173

# ---- IA ----
# LLM_PROVIDER: anthropic | openai | mock | auto (default: auto)
LLM_PROVIDER=auto
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ---- Portal Único Siscomex (NCM oficial — desligado por padrão) ----
# SISCOMEX_PROVIDER: portal-unico | stub | auto (default: auto)
# SISCOMEX_AMBIENTE: validacao | homologacao | producao
# Opção A — certificado e-CNPJ A1 na VPS (recomendado):
# SISCOMEX_CERT_PATH=/etc/cia-alpha44/certs/alpha44.pfx
# SISCOMEX_CERT_PASSWORD=
# Opção B — chaves de acesso geradas no Portal Único:
# SISCOMEX_CLIENT_ID=
# SISCOMEX_CLIENT_SECRET=
# SISCOMEX_ATIVO=true   # consultas CLSF/TTCE ao vivo com certificado
# SISCOMEX_ROLE_TYPE=IMPEXP
# SISCOMEX_CODIGO_PAIS=160   # China (ComexStat / origem padrão)
# Guia: docs/SISCOMEX.md

# ---- OCR (PDF / imagem) — https://ocr.space/ocrapi/freekey.aspx ----
# OCR_PROVIDER: ocrspace | http | mock | auto
OCR_PROVIDER=auto
OCR_API_KEY=
OCR_API_URL=
OCR_LANGUAGE=chs
OCR_API_HEADER=Authorization

# ---- Banco (Render Postgres ou túnel VPS) ----
DATABASE_URL=

# ---- Frontend (local ou Vercel) ----
# Produção: URL pública da API Render, sem barra final
VITE_API_URL=http://localhost:3333

# ---- Auth Clerk (API back + Vercel front) ----
# API VPS: CLERK_SECRET_KEY=sk_test_... ou sk_live_...
CLERK_SECRET_KEY=
# Dev sem Clerk: header x-demo-auth:1 (front envia automaticamente). Desligar: AUTH_DEMO_FALLBACK=off
AUTH_DEMO_FALLBACK=
# Rate limit (por tenant/hora)
# RL_CLASSIFICAR_MAX=30
# RL_PARSE_MAX=30
# RL_NCM_CONFERIR_MAX=120

# ---- Auth Clerk (Vercel) — produção exige key; dev sem key usa login demo ----
# VITE_CLERK_PUBLISHABLE_KEY=pk_test_...
# VITE_DEMO_EMAIL=demo@cia-alpha44.com.br
# VITE_DEMO_PASSWORD=CiaAlpha44!
