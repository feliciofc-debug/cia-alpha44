{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm ci",
  "buildCommand": "VITE_API_URL= npm run build:web",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://api2.amzofertas.com.br/cia/api/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
