// CIA / Alpha 44 — persistência de cotações
// Multi-tenant: tenantId em todas as cotações; v1 usa só slug "default" (seed).
// Resultado fiscal: snapshot JSON (ResultadoCotacao do @cia/fiscal-engine).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Importadora / cliente do SaaS (v1: apenas tenant default).
model Tenant {
  id       String    @id @default(cuid())
  nome     String
  slug     String    @unique
  criadoEm DateTime  @default(now())
  cotacoes Cotacao[]
}

enum CotacaoStatus {
  RASCUNHO
  CALCULADA
  ARQUIVADA
}

enum CanalAduaneiro {
  VERDE_PROVAVEL
  AMARELO_TECNICO
  VERMELHO_TECNICO
  CINZA_VALORACAO
}

model Cotacao {
  id       String @id @default(cuid())
  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  // --- cabeçalho (espelha @cia/shared cotacaoSchema) ---
  empresaTrade          String  @default("")
  cliente               String  @default("")
  benefFiscal           String  @default("ALAGOAS")
  moeda                 String  @default("US$")
  /// Moeda detectada na planilha do fornecedor (P2c — ex.: EUR)
  moedaPlanilha         String?
  cambio                Decimal @db.Decimal(12, 6)
  freteTotalUS          Decimal @db.Decimal(14, 4)
  adicionaisVaUS        Decimal @default(0) @db.Decimal(14, 4)
  reducaoBaseUS         Decimal @default(0) @db.Decimal(14, 4)
  siscomex              Decimal @default(0) @db.Decimal(14, 2)
  antidumpingBRL        Decimal @default(0) @db.Decimal(14, 2)
  incoterm              String  @default("CFR")
  origem                String  @default("RJ")
  destino               String  @default("SP")
  /// UF estabelecimento vendedor (P2.2 ICMS)
  ufEmpresa             String  @default("AL")
  /// AL_DIFERIDO | NORMAL
  regimeIcms            String  @default("AL_DIFERIDO")
  /// true quando icmsSaida em params é override/legado divergente do resolver
  icmsSaidaManualFlag   Boolean @default(false)
  /// Avisos fiscais persistidos (JSON string[])
  avisosFiscais         Json    @default("[]")
  outrasDespesasBaseBRL Decimal? @db.Decimal(14, 2)
  /// ParamsSaida — mesmo shape do shared (markupPct, pisSaida, etc.)
  params                Json

  // --- grade / listagem (desnormalizado no save/recalcular) ---
  status            CotacaoStatus     @default(RASCUNHO)
  totalBRL          Decimal?          @db.Decimal(16, 2)
  totalUS           Decimal?          @db.Decimal(14, 4)
  canalPredominante CanalAduaneiro?

  /// Snapshot completo ResultadoCotacao (@cia/fiscal-engine)
  resultadoCalculo Json?
  calculadoEm      DateTime?

  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  itens    Item[]
  despesas Despesa[]

  @@index([tenantId, criadoEm(sort: Desc)])
  @@index([tenantId, status])
  @@index([cliente])
}

model Item {
  id        String  @id @default(cuid())
  cotacaoId String
  cotacao   Cotacao @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)

  ordem Int

  descOriginal      String   @db.Text
  descPt            String   @default("") @db.Text
  descDuimp         String   @default("") @db.Text
  ncm               String
  ncmCandidatos     Json     @default("[]")
  pesoBrutoKg       Decimal? @db.Decimal(12, 4)
  pesoLiqKg         Decimal  @db.Decimal(12, 4)
  qtd               Decimal? @db.Decimal(14, 4)
  fobUnitarioUS     Decimal? @db.Decimal(14, 4)
  fobTotalUS        Decimal  @db.Decimal(14, 4)
  aliquotas         Json
  aliquotasOverride Boolean  @default(false)
  benchmark         Json?
  calibracao        Json?
  risco             Json?
  anuencia          Json     @default("[]")
  antidumping       Boolean  @default(false)
  /// Caminho relativo em data/fotos/ (ex.: cotacaoId/0.jpg)
  fotoPath          String?
  /// Metadados estendidos (uso, material, ncmFonte, fobKgFonte, compatibilidade…)
  meta              Json     @default("{}")

  @@index([cotacaoId])
  @@index([ncm])
}

model Despesa {
  id        String  @id @default(cuid())
  cotacaoId String
  cotacao   Cotacao @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)

  ordem           Int
  nome            String
  valorBRL        Decimal @db.Decimal(14, 2)
  entraBaseSaida  Boolean @default(true)
  entraBaseNota   Boolean @default(true)

  @@index([cotacaoId])
}
